      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var data = pm.response.json();",
              "pm.test(\"ID matches environment\", function () {",
              "  pm.expect(data.id).to.eql(pm.environment.get(\"resourceId\"));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
