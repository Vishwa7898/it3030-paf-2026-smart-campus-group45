            "api",
            "resources"
          ],
          "query": [
            {
              "key": "type",
              "value": "LAB"
            },
            {
              "key": "minCapacity",
              "value": "20"
            },
            {
              "key": "status",
              "value": "ACTIVE"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
