    {
      "name": "07 - Partial Update Resource (PATCH)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"capacity\": 45,\n  \"description\": \"Updated lab capacity and details\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/resources/{{resourceId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "resources",
            "{{resourceId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var data = pm.response.json();",
              "pm.test(\"Capacity updated\", function () {",
              "  pm.expect(data.capacity).to.eql(45);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "08 - Update Resource Status",
      "request": {
        "method": "PATCH",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/resources/{{resourceId}}/status?status=MAINTENANCE",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "resources",
            "{{resourceId}}",
            "status"
          ],
          "query": [
            {
              "key": "status",
              "value": "MAINTENANCE"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var data = pm.response.json();",
              "pm.test(\"Status changed to MAINTENANCE\", function () {",
              "  pm.expect(data.status).to.eql(\"MAINTENANCE\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
