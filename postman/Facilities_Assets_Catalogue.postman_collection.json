              "});",
              "pm.test(\"Response is array\", function () {",
              "  pm.expect(pm.response.json()).to.be.an(\"array\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05 - Get Resource By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/resources/{{resourceId}}",
          "host": [
            "{{baseUrl}}"
