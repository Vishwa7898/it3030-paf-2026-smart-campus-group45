  "item": [
    {
      "name": "01 - Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - Create Resource (JSON)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"AI Lab 01\",\n  \"type\": \"LAB\",\n  \"location\": \"Building A - Room 205\",\n  \"capacity\": 40,\n  \"status\": \"ACTIVE\",\n  \"description\": \"Lab for AI practical sessions\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/resources",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "resources"
          ]
        },
        "description": "Creates a new resource and stores returned id to environment variable resourceId."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 201\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "var data = pm.response.json();",
              "pm.test(\"Response has resource id\", function () {",
              "  pm.expect(data).to.have.property(\"id\");",
              "});",
              "",
              "pm.environment.set(\"resourceId\", data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 - Get All Resources",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/resources",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "resources"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response is array\", function () {",
              "  pm.expect(pm.response.json()).to.be.an(\"array\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "04 - Filter Resources",
      "request": {
        "method": "GET",
        "header": [],
